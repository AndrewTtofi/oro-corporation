# syntax=docker/dockerfile:1.7
# Dev-only image: brings deps + Prisma client. Source is bind-mounted at runtime
# so edits trigger Next.js hot reload and tsx watch for the worker.
FROM node:26-alpine
RUN apk add --no-cache libc6-compat python3 make g++ openssl curl
WORKDIR /app
COPY package.json package-lock.json ./
# --legacy-peer-deps to match the prod Dockerfile and CI (next-auth's beta peer
# ranges otherwise trip strict resolution).
RUN npm install --no-audit --no-fund --legacy-peer-deps
COPY prisma ./prisma
RUN npx prisma generate
EXPOSE 3000
