# ───────────────────────────────────────────────────────────────────────
#  Environment variables (white-label fiduciary platform)
#  Required keys cause a loud boot failure. Optional keys gate features.
#  Copy to `.env` (local) or set via Docker compose `env_file` (prod).
# ───────────────────────────────────────────────────────────────────────

# ── Core ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://oro:oro@db:5432/oro?schema=public
APP_URL=https://localhost
AUTH_URL=https://localhost
# Generate with: openssl rand -base64 48
AUTH_SECRET=replace-me-with-a-long-random-string-of-at-least-32-chars

# ── File storage (AES-256-GCM envelope) ────────────────────────────────
# 32 raw bytes, base64-encoded. Generate with: openssl rand -base64 32
ENCRYPTION_KEY_B64=replace-me-with-base64-of-32-random-bytes-please-use-openssl

STORAGE_DRIVER=local           # local | s3
STORAGE_LOCAL_DIR=/data/docs

# Only used when STORAGE_DRIVER=s3 (R2 / MinIO / S3-compatible)
# S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_BUCKET=oro-docs
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_FORCE_PATH_STYLE=false

# ── Email ──────────────────────────────────────────────────────────────
EMAIL_DRIVER=smtp              # smtp | resend | console
SMTP_HOST=mail                 # `mail` is the mailpit container in dev
SMTP_PORT=1025
# SMTP_USER=
# SMTP_PASS=
SMTP_FROM="no-reply@localhost"

# Only used when EMAIL_DRIVER=resend
# RESEND_API_KEY=

# ── OAuth (off by default — owner has no client IDs yet) ───────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=

# ── WhatsApp / Twilio (P1, env-gated no-op until set) ──────────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=+14155238886

# ── App behavior ───────────────────────────────────────────────────────
NODE_ENV=production
SEED_ON_BOOT=false             # set to true on first boot for demo data

# ── White-label brand ──────────────────────────────────────────────────
# The firm this deployment is branded for. Set ONCE (as the COMPANY_NAME
# GitHub Actions variable in CI/CD); the deploy applies it to the app's
# branding (emails, calendar, UI, reference prefixes, legal pages) and the
# deploy notifier. Empty → neutral "the platform" wording.
# COMPANY_NAME=Acme Trust

# ── Super admin (platform operator / code owner) ───────────────────────
# Comma-separated emails. Only these users can change the plan tier in the
# admin UI; everyone else sees the plan read-only. Leave empty to lock the
# plan entirely (no one can change it via the UI).
# SUPER_ADMIN_EMAILS=you@yourplatform.com
