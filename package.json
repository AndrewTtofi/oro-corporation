{
  "name": "oro",
  "version": "0.1.0",
  "private": true,
  "description": "ORO — client-onboarding portal for ORO Corporate Services (Cyprus). Self-hosted on Lightsail.",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "prisma generate && next build",
    "start": "next start -p 3000",
    "worker": "node ./dist-worker/worker/index.js",
    "worker:dev": "tsx watch src/worker/index.ts",
    "worker:build": "tsc -p tsconfig.worker.json && tsc-alias -p tsconfig.worker.json",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "test": "vitest run",
    "test:unit": "vitest run --project=unit",
    "test:integration": "vitest run --project=integration",
    "test:watch": "vitest --project=unit",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.4",
    "@aws-sdk/client-s3": "^3.687.0",
    "@aws-sdk/s3-request-presigner": "^3.687.0",
    "@prisma/client": "^5.22.0",
    "argon2": "^0.41.1",
    "ical-generator": "^7.2.0",
    "next": "15.5.18",
    "next-auth": "5.0.0-beta.25",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.10.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testcontainers/postgresql": "^12.0.0",
    "@types/node": "^26.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.7",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.14.0",
    "eslint-config-next": "15.5.18",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.14",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=20"
  }
}
