{
  "name": "oro",
  "version": "1.1.0",
  "private": true,
  "description": "ORO — client-onboarding portal for ORO Corporate Services (Cyprus). Self-hosted on Lightsail.",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "prisma generate && next build",
    "start": "next start -p 3000",
    "worker": "node ./dist-worker/worker/index.js",
    "worker:dev": "tsx watch src/worker/index.ts",
    "worker:build": "tsc -p tsconfig.worker.json && tsc-alias -p tsconfig.worker.json",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "test": "vitest run",
    "test:unit": "vitest run --project=unit",
    "test:integration": "vitest run --project=integration",
    "test:watch": "vitest --project=unit",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.4",
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "argon2": "^0.44.0",
    "ical-generator": "^11.0.0",
    "next": "16.2.9",
    "next-auth": "5.0.0-beta.31",
    "node-cron": "^4.5.0",
    "nodemailer": "^9.0.3",
    "pg": "8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@testcontainers/postgresql": "^12.0.3",
    "@types/node": "^26.0.1",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.5.2",
    "eslint": "^9.14.0",
    "eslint-config-next": "16.2.9",
    "postcss": "^8.5.16",
    "prisma": "7.8.0",
    "tailwindcss": "^3.4.14",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=22"
  }
}
