# ORO nightly backup — systemd timer. Fires backup.sh at 03:00 server-local
# every day, with a randomized delay to avoid thundering-herd at the datacenter.
# Persistent=true means a missed run (box was off) fires on next boot.

[Unit]
Description=Run ORO backup nightly at 03:00

[Timer]
OnCalendar=*-*-* 03:00:00
RandomizedDelaySec=900
Persistent=true

[Install]
WantedBy=timers.target
